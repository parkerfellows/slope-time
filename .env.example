# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Google Weather API (Google Maps Platform)
GOOGLE_WEATHER_API_KEY=

# OpenWeatherMap (future fallback)
OPENWEATHER_API_KEY=

# Supabase (server-only — never exposed to browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Supabase (browser-safe — same values, NEXT_PUBLIC_ prefix required by Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini (used for resort conditions chat)
GEMINI_API_KEY=
